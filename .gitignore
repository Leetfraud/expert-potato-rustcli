# Generated by Cargo
# will have compiled files and executables
/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# (For a simple personal CLI app, either is fine, but ignoring it keeps things clean)
Cargo.lock

# Ignore our generated HTML export files
*.html

# Ignore the actual notes database so your personal thoughts stay private!
notes.txt

# Backup files generated by rustfmt
**/*.rs.bk